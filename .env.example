# ── AI Stack ──────────────────────────────────────────
OPENAI_API_KEY=                    # OpenAI Codex API Key
GROQ_API_KEY=                      # Groq Llama 3.1 70B API Key
NVIDIA_API_KEY=                    # NVIDIA NIMs API Key
SARVAM_API_KEY=                    # Sarvam AI voice + translation API Key
TINYFISH_API_KEY=                  # TinyFish web search API Key

# ── Data Sources ──────────────────────────────────────
GEM_API_KEY=                       # GeM portal API key (free from gem.gov.in)
GEM_API_BASE=https://api.gem.gov.in/v2

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://darpan_user:darpan_password@localhost:5432/darpan
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
SUPABASE_URL=                      # Supabase Project URL
SUPABASE_ANON_KEY=                 # Supabase Anonymous Key
SUPABASE_SERVICE_ROLE_KEY=         # Supabase Service Role Key
SECRET_KEY=                        # 64-char random hexadecimal string

# ── RTI Filing Account ────────────────────────────────
RTI_EMAIL=                         # rtionline.gov.in registered email
RTI_PASSWORD=                      # rtionline.gov.in registered password
RTI_APPLICANT_NAME=Darpan Vigilance Foundation
RTI_APPLICANT_ADDRESS=             # Physical address for physical RTI responses

# ── Messaging ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=                # Twilio SID for outbound Hindi warning calls
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_API_KEY=                  # WhatsApp Business API key
WHATSAPP_PHONE_ID=
RESEND_API_KEY=                    # Resend API Key for transactional alerts

# ── App ───────────────────────────────────────────────
ADMIN_EMAIL=admin@darpan.gov.in
ENVIRONMENT=development            # development | production
FRONTEND_URL=http://localhost:3000
SENTRY_DSN=                        # Optional error tracking Sentry DSN
